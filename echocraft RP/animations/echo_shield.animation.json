{
	"format_version": "1.8.0",
	"animations": {
		"animation.echo_shield.first_person_mainhand_wield": {
			"loop": true,
			"bones": {
				"shield": {
					"rotation": [
						"variable.main_hand_first_person_rot_x",
						"variable.main_hand_first_person_rot_y",
						"variable.main_hand_first_person_rot_z"
					],
					"position": [
						"variable.main_hand_first_person_pos_x",
						"variable.main_hand_first_person_pos_y",
						"variable.main_hand_first_person_pos_z"
					]
				}
			}
		},
		"animation.echo_shield.first_person.offhand.wield": {
			"loop": true,
			"bones": {
				"shield": {
					"rotation": [
						"variable.off_hand_first_person_rot_x",
						"variable.off_hand_first_person_rot_y",
						"variable.off_hand_first_person_rot_z"
					],
					"position": [
						"variable.off_hand_first_person_pos_x",
						"variable.off_hand_first_person_pos_y",
						"variable.is_using_bow ? variable.off_hand_first_person_with_bow_pos_z : variable.off_hand_first_person_pos_z"
					]
				}
			}
		},
		"animation.echo_shield.first_person.offhand.block": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.25,
			"bones": {
				"shield": {
					"rotation": [
						"variable.off_hand_first_person_rot_x",
						"variable.off_hand_first_person_rot_y",
						"variable.off_hand_first_person_rot_z + 10.0"
					],
					"position": {
						"0.0": [
							"variable.off_hand_first_person_pos_x + 0.5",
							"variable.off_hand_first_person_pos_y",
							"variable.is_using_bow ? variable.off_hand_first_person_with_bow_pos_z : variable.off_hand_first_person_pos_z"
						],
						"0.1": [
							"variable.off_hand_first_person_pos_x + 0.5",
							"variable.off_hand_first_person_pos_y + 3.2",
							"variable.is_using_bow ? variable.off_hand_first_person_with_bow_pos_z : variable.off_hand_first_person_pos_z + 1.5"
						]
					}
				}
			}
		},
		"animation.echo_shield.first_person.mainhand.block": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.25,
			"bones": {
				"shield": {
					"rotation": [
						"variable.main_hand_first_person_rot_x",
						"variable.main_hand_first_person_rot_y - 10.0",
						"variable.main_hand_first_person_rot_z"
					],
					"position": {
						"0.0": [
							"variable.main_hand_first_person_pos_x - 2",
							"variable.main_hand_first_person_pos_y",
							"variable.main_hand_first_person_pos_z"
						],
						"0.1": [
							"variable.main_hand_first_person_pos_x - 2",
							"variable.main_hand_first_person_pos_y - 2",
							"variable.main_hand_first_person_pos_z - 2"
						]
					}
				}
			}
		},
		"animation.echo_shield.third_person.mainhand.wield": {
			"loop": true,
			"bones": {
				"shield": {
					"rotation": [
						-90,
						-2.5,
						90
					],
					"position": [
						"c.item_slot == 'main_hand' ? -0.4 : -1.6",
						9,
						9.3
					],
					"scale": [
						"c.item_slot == 'main_hand' ? 1.0 : -1.0",
						-1,
						"c.item_slot == 'main_hand' ? -1.0 : 1.0"
					]
				}
			}
		},
		"animation.echo_shield.third_person.mainhand.block": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.25,
			"bones": {
				"shield": {
					"rotation": [
						-5,
						1.1,
						5
					],
					"position": [
						3.5,
						-5.5,
						-9
					]
				}
			}
		},
		"animation.echo_shield.third_person.offhand.block": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.25,
			"bones": {
				"shield": {
					"rotation": [
						-5,
						1.1,
						-2.7
					],
					"position": [
						-2.5,
						-5.5,
						-9
					]
				}
			}
		},
		"animation.echo_shield.third_person.offhand.wield": {
			"loop": true,
			"bones": {
				"shield": {
					"rotation": [
						-90,
						-2.5,
						-90
					],
					"position": [
						"c.item_slot == 'off_hand' ? -1.5 : -1.6",
						9,
						9.3
					],
					"scale": [
						"c.item_slot == 'off_hand' ? 1.0 : -1.0",
						-1,
						"c.item_slot == 'off_hand' ? -1.0 : 1.0"
					]
				}
			}
		}
	}
}